# AegisRoute — example environment
#
# Copy to `.env` for local host runs (`cp .env.example .env`). Host-run Make
# targets source `.env` into the environment; in Compose the services get env
# from the `environment:` block instead. Uppercase env vars only.
#
# All credential values in this file are LOCAL-ONLY DEMO values — safe to
# commit, never valid outside a local dev stack.

# --- App basics ---------------------------------------------------------
# Deployment environment name (dev|test|prod-style label, informational).
APP_ENV=dev
# Port gateway-api listens on (HTTP + /metrics).
APP_PORT=8080
# slog level: debug|info|warn|error.
LOG_LEVEL=info

# --- Backing stores -----------------------------------------------------
# PostgreSQL DSN. `localhost` for host runs; Compose overrides to `postgres`.
DATABASE_URL=postgres://aegisroute:aegisroute@localhost:5432/aegisroute?sslmode=disable
# Redis address. `localhost` for host runs; Compose overrides to `redis:6379`.
REDIS_ADDR=localhost:6379
# Redis logical database index.
REDIS_DB=0

# --- Secrets / credentials ---------------------------------------------
# HMAC-SHA256 secret for API-key hashing. Must be >= 32 bytes.
# LOCAL-ONLY DEMO — safe to commit.
APP_KEY_HASH_SECRET=dev_only_change_me_32_bytes_minimum
# Token for admin routes (/api/v1/backends*, /api/v1/routing-policies*).
# LOCAL-ONLY DEMO — safe to commit.
ADMIN_TOKEN=dev_admin_token
# Demo tenant API key inserted by the seeder (stored only as its HMAC).
# LOCAL-ONLY DEMO — safe to commit.
DEV_API_KEY=sg_dev_key_123

# --- Startup behavior (demo convenience, not a production pattern) ------
# Run embedded migrations on boot. Real deployments: run `-migrate` as a
# discrete deploy step and set this to false.
AEGISROUTE_AUTO_MIGRATE=true
# Run the idempotent demo seeder on boot.
AEGISROUTE_AUTO_SEED=true

# --- Request controls ---------------------------------------------------
# Per-key rate limit, queries per second. Must be > 0.
RATE_LIMIT_QPS=20
# Response cache TTL, seconds.
CACHE_TTL_SECONDS=300
# Idempotency record TTL, seconds (default 24h).
IDEMPOTENCY_TTL_SECONDS=86400

# --- Upstream backend calls (per logical request) ------------------------
# Timeout for one upstream backend HTTP call, milliseconds.
BACKEND_TIMEOUT_MS=5000
# Inference HTTP retry layer: max attempts per upstream call on transient
# failure (timeout, conn error, 502/503/504). Distinct from
# WORKER_MAX_ITEM_ATTEMPTS — the two layers stack.
RETRY_MAX_ATTEMPTS=3
# Retry backoff base / cap, milliseconds.
RETRY_BASE_MS=50
RETRY_MAX_MS=2000

# --- Circuit breaker ----------------------------------------------------
# Consecutive failures before a backend's breaker opens.
CB_FAILURE_THRESHOLD=5
# How long an open breaker waits before half-open probing, milliseconds.
CB_COOLDOWN_MS=10000

# --- control-worker -----------------------------------------------------
# Bounded worker pool size.
WORKER_CONCURRENCY=8
# Port for the worker's /healthz + /metrics.
WORKER_METRICS_PORT=9100
# Worker item attempts layer: how many stream redeliveries/claims a batch
# item gets before the DLQ. Distinct from RETRY_MAX_ATTEMPTS (they stack).
WORKER_MAX_ITEM_ATTEMPTS=3

# --- Redis Stream (batch queue) ------------------------------------------
STREAM_KEY=aegisroute:batch_jobs
STREAM_GROUP=aegisroute-workers

# --- Seeder backend URLs -------------------------------------------------
# Defaults are Compose service names. For a host-local run without Compose,
# override to http://localhost:8081 / http://localhost:8082.
SEED_BACKEND_FAST_URL=http://mock-llm-fast:8081
SEED_BACKEND_CHEAP_URL=http://mock-llm-cheap:8082
